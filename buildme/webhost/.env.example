# PostgreSQL
POSTGRES_DB=MaxAttack
POSTGRES_USER=MaxAttack
POSTGRES_PASSWORD=Postgres_Password_changeMe!

# Redis
REDIS_PASSWORD=This-is-a-poor-Redis-password!

# Flask
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production
WEB_PORT=7077

# Engine
ENGINE_NAME=engine-default
ENGINE_NETWORK_TAG=engine-network-default

# LLM (optional — OpenAI-compatible API)
# LLM_ENDPOINT=http://192.168.1.x:11434
# LLM_API_KEY=your-api-key-if-required
# LLM_MODEL=llama3.2
#
# When LLM_ENDPOINT is set:
#   - Findings extraction is enhanced with AI analysis
#   - "Analyze with AI" button appears on phase output
#   - Reports include an AI-generated executive summary
